
{
  "appId": "com.jeanieiq.aquipax",
  "appName": "Aquipax",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://aquipax.com/app.html",
    "cleartext": true,
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a1628",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a1628"
    }
  }
}
